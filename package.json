{
  "name": "hanwudi-arch-openclaw",
  "version": "1.0.0",
  "description": "AI Agent Team Architecture - 8 specialized personas for LLM-powered teams",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "persona",
    "team",
    "metagapt",
    "multi-agent",
    "workflow",
    "hanwudi",
    "minimax"
  ],
  "author": "dingzhilin1990",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dingzhilin1990/hanwudi-team.git"
  },
  "bugs": {
    "url": "https://github.com/dingzhilin1990/hanwudi-team/issues"
  },
  "homepage": "https://github.com/dingzhilin1990/hanwudi-team#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.39",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
